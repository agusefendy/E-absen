<IfModule mod_rewrite.c>
RewriteEngine on

RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.*)$ $1.php


RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.*)$ $1.html

</IfModule>

<IfModule mod_rewrite.c>
RewriteEngine On
RewriteRule ^index-([a-zA-Z0-9_-]+)$ index.php?idkelas=$1
RewriteRule ^siswa-([a-zA-Z0-9_-]+)$ siswa.php?idkelas=$1
RewriteRule ^buatqr-([a-zA-Z0-9_-]+)$ buatqr.php?idkelas=$1
RewriteRule ^unduh-([a-zA-Z0-9_-]+)$ unduh.php?konten=$1
RewriteRule ^absensi-([a-zA-Z0-9_-]+)$ absensi.php?idkelas=$1
RewriteRule ^datauser-([a-zA-Z0-9_-]+)$ datauser.php?idguru=$1
RewriteRule ^reset-datauser-([a-zA-Z0-9_-]+)$ datauser.php?reset=$1
</IfModule>